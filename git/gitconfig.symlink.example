# Sample gitconfig
#

[hub]
        protocol = https
[user]
        name = Sean Kay
        email = f.sean.kay@gmail.com
        helper = osxkeychain
[alias]
        co = checkout
        count   = !git shortlog -sn
        head = !git r -1
        h = !git head
        l = "!. ~/.githelpers && pretty_git_log"
[color]
        diff = auto
        status = auto
        branch = auto
        ui = true
[core]
        excludesfile = ~/.gitignore
        editor = nvim
[apply]
        whitespace = nowarn
[mergetool]
        keepBackup = false


[difftool]
        prompt = false
[help]
        autocorrect = 1
[push]
        # See `git help config` (search for push.default)
        # for more information on different options of the below setting.
        #
        # Setting to git 2.0 default to surpress warning message
        default = simple
[branch]
        autosetuprebase = always
[merge]
	tool = vimdiff
